# EvalForge Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEV:  copy this file to backend/.env and fill in your values
# PRODUCTION: set these as environment variables in Railway / your platform
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider: Ollama ─────────────────────────────────────────────────────
# Local:      ollama serve  (default below works out of the box)
# Production: point to a hosted Ollama instance (self-hosted VPS or GPU cloud)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev:  SQLite file (default, no setup needed)
# Production: swap for a Postgres URL from Railway / Supabase / Neon
#   DATABASE_URL=postgresql://user:password@host:5432/evalforge
DATABASE_URL=sqlite:///./evalforge.db

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev:  default (localhost:3000) is used when this is not set
# Production: set to your Vercel URL
#   ALLOWED_ORIGINS=https://evalforge.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend API URL (Next.js) ────────────────────────────────────────────────
# Set in frontend/.env.local for local dev, or in Vercel dashboard for prod.
# Must be prefixed NEXT_PUBLIC_ to be accessible in the browser.
# Local dev:  http://localhost:8000  (default in src/lib/api.ts)
# Production: https://your-backend.railway.app
#   NEXT_PUBLIC_API_URL=https://your-backend.railway.app

# ── LangSmith (optional — evaluation tracking UI) ────────────────────────────
# Get your key from https://smith.langchain.com
# If not set, LangSmith tracking is silently skipped — app still works fully.
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=evalforge
