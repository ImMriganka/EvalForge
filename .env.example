# EvalForge Environment Variables
# Copy this file to backend/.env and fill in your keys

# ── LLM Provider: Ollama (local, no API key needed) ──────────────────────────
# Ollama must be running: `ollama serve`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── LangSmith (optional — evaluation tracking UI) ────────────────────────────
# Get your key from https://smith.langchain.com
# If not set, LangSmith tracking is silently skipped — app still works fully.
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=evalforge

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for local dev; swap URL for Postgres in production
DATABASE_URL=sqlite:///./evalforge.db
